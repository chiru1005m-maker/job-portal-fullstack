# 1. DATABASE CONFIG - Switching to H2 (Local File)
# Simplified H2 URL to avoid the "Feature not supported" error
spring.datasource.url=jdbc:h2:file:./data/jobportal;AUTO_SERVER=TRUE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver

# 2. JPA SETTINGS
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# 3. SECURITY
# Using the secret from your previous file
APP_JWT_SECRET=7a6b4c92d1e5f8a3b0c9d8e7f6a5b4c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7